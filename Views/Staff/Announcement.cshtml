@model List<Patient_Enquiry_System_version_2.Models.Announcement>

@{ ViewBag.Title = "Send Announcement"; }

<h2>📢 Send Announcement to All Patients</h2>

@if (TempData["Result"] != null)
{
    <div style="background:#d4edda; padding:10px; border-radius:6px; margin-bottom:15px;">
        <b>@TempData["Result"]</b>
    </div>
}

<form method="post" action="@Url.Action("SendAnnouncement", "Staff")">
    <textarea name="Message" rows="5" cols="60"
              placeholder="Type your announcement here..."
              required></textarea>
    <br><br>
    <button type="submit"
            style="background:#007bff; color:white; padding:8px 20px; border:none; border-radius:4px; cursor:pointer;">
        Send to All Patients
    </button>
</form>

<hr>

<h3>Announcement History</h3>

@if (Model != null && Model.Count > 0)
{
    <table border="1" cellpadding="8" style="border-collapse:collapse; width:100%;">
        <tr style="background:#f0f0f0;">
            <th>Date</th>
            <th>Message</th>
            <th>Sent</th>
            <th>Failed</th>
        </tr>
        @foreach (var a in Model)
        {
            <tr>
                <td>@a.SentAt.ToLocalTime()</td>
                <td>@a.Message</td>
                <td style="color:green;">@a.TotalSent</td>
                <td style="color:red;">@a.TotalFailed</td>
            </tr>
        }
    </table>
}
else
{
    <p>No announcements sent yet.</p>
}

<br>
<a href="@Url.Action("Index","Staff")">← Back to Dashboard</a>